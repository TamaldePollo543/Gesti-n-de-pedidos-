# Copia este archivo como .env.local y ajusta los valores

# URL base de la API REST (modulo central)
VITE_API_BASE_URL=https://api.restaurant.local
# Compatibilidad retroactiva (si ya usabas esta variable)
VITE_API_URL=https://api.mesaplus.local/v1

# Modo local simulado (poner true solo para pruebas sin backend real)
VITE_USE_MOCK=false

# Fuente del menu: por defecto usa API central (recomendado).
# Pon true solo si quieres leer menu_items directo desde Supabase REST.
VITE_USE_DIRECT_SUPABASE_MENU=false

# Pedidos por API (activar cuando el endpoint /orders exista en backend)
VITE_ENABLE_ORDERS_API=false
# Edicion remota de pedidos (activar solo cuando backend soporte PATCH/PUT /orders/:id)
VITE_ENABLE_ORDER_EDIT_API=false

# Cocina: limpieza visual y estabilidad de estado en UI
# Tiempo para ocultar pedidos listos/servidos/cancelados (ms)
VITE_KITCHEN_HIDE_FINISHED_AFTER_MS=30000
# Tiempo de proteccion para evitar rebote visual de estado tras actualizar (ms)
VITE_KITCHEN_STATUS_OVERRIDE_TTL_MS=15000

# ────────────────────────────────────────────────────────────────────────
# TIEMPO REAL - Elige una opcion:
# ────────────────────────────────────────────────────────────────────────

# Opción A: RECOMENDADO - Usar Supabase Realtime (sin Socket.io)
# Si configuras estos, Socket.io no se necesita
VITE_SUPABASE_URL=https://cohlhobfkbzpqtcaqqxb.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_2gLD3ima5Dzp7m-xhA3-ZA_R58ABjpY

# Opción B: Socket.io (fallback si Supabase no está disponible)
# Deja esto vacío si usas solo Supabase. Si tienes un servidor Socket.io real:
# VITE_WS_URL=https://api.restaurant.local

# ────────────────────────────────────────────────────────────────────────
# NOTA: Si dejas WS_URL=https://api.mesaplus.local, se omitirá Socket.io
# porque es un localhost de desarrollo y no es accesible desde el navegador.
# Configura una URL real o deja vacío para evitar errores DNS.
# ────────────────────────────────────────────────────────────────────────

